# =============================================================================
# .env.example — riferimento variabili d'ambiente FortySeal
#
# Copia in .env e compila i valori. Il file .env NON entra nell'immagine
# (vedi .dockerignore) ma viene letto da docker-compose (env_file + sostituzione).
#
# Legenda:
#   [OBBLIGATORIO] l'app non parte senza
#   [COMPOSE]      già impostata da docker-compose.yml (qui solo per chiarezza)
#   [OPZIONALE]    ha un default ragionevole
# =============================================================================

# --- Core Django -------------------------------------------------------------
SECRET_KEY=                         # [OBBLIGATORIO] genera: python -c "import secrets;print(secrets.token_urlsafe(64))"
DEBUG=True                          # [OPZIONALE] True per test locale http; False in produzione (richiede TLS davanti)
ALLOWED_HOSTS=localhost,127.0.0.1   # [OPZIONALE] aggiungi il dominio in produzione

# --- Database ----------------------------------------------------------------
# Per il docker-compose usa i campi DB_* qui sotto (Postgres del compose).
# DB_HOST e DB_PORT sono forzati dal compose (db:5432): non serve impostarli qui.
USE_SQLITE=False                    # [COMPOSE] False con Postgres
DATABASE_URL=                       # [COMPOSE] lascia VUOTA: il compose la azzera (evita ssl_require)
DB_NAME=fortyseal                   # deve combaciare con POSTGRES_DB del servizio db
DB_USER=fortyseal                   # deve combaciare con POSTGRES_USER
DB_PASSWORD=changeme-in-env         # [OBBLIGATORIO in prod] deve combaciare con POSTGRES_PASSWORD

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0      # [COMPOSE] broker Celery + result backend

# --- Celery / job periodici gateway ------------------------------------------
# CELERY_TASK_ALWAYS_EAGER=False     # [OPZIONALE] True = esegui i task in-process (test)
# Job: reset cap mensile, integrità notturna, API key in scadenza, purge audit.
# Avvio: `celery -A Cripto worker -l info` + `celery -A Cripto beat -l info`
# In alternativa (Render Cron Jobs): `python manage.py gateway_cron --jobs all`

# --- Gateway webhook (consegna asincrona, non bloccante) ---------------------
# GATEWAY_WEBHOOK_BACKEND=thread     # 'thread' (default) | 'celery'
# GATEWAY_WEBHOOK_TIMEOUT_SEC=8
# GATEWAY_WEBHOOK_MAX_RETRIES=3
# GATEWAY_WEBHOOK_THREAD_WORKERS=4

# --- Admin / sicurezza -------------------------------------------------------
DJANGO_ADMIN_URL=secure-admin       # [OPZIONALE] path admin segreto (default: secure-admin)
ADMIN_NAME=Admin FortySeal          # [OPZIONALE]
ADMIN_EMAIL=                        # [OPZIONALE]
SERVE_MEDIA=1                       # [OPZIONALE] 1 per servire /media senza reverse proxy

# --- Chiavi crittografiche (base64) ------------------------------------------
# Generale: per AES a 256 bit -> python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# IMPORTANTE: una volta in produzione NON cambiarle, altrimenti i dati cifrati
# diventano illeggibili (vale soprattutto per CRL_KEY_DERIVATION_SALT e PQC_MASTER_KEY).
AES256_KEY=                         # [OBBLIGATORIO] l'app non parte senza
FIELD_AES256_KEY=                   # [OBBLIGATORIO]
PBKDF2_SALT=                        # [OBBLIGATORIO]
PQC_MASTER_KEY=                     # [OBBLIGATORIO]
CRL_KEY_DERIVATION_SALT=            # [OPZIONALE ma consigliata] stabile nel tempo
FIELD_ENCRYPTION_KEY=               # [OPZIONALE]
CRYPTO_ALGORITHM=AES256_GCM         # [OPZIONALE]
USE_LEGACY_FERNET=False             # [OPZIONALE]
PQC_BLOCK_V0=False                  # [OPZIONALE] blocca decryption Kyber v0 legacy

# --- Email (SMTP) ------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com           # [OPZIONALE]
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
SITE_URL=http://localhost:8000      # URL pubblico usato nei link delle email

# --- Backup blockchain -------------------------------------------------------
AUTO_BACKUP_ENABLED=True            # [OPZIONALE]
AUTO_BACKUP_INTERVAL_MINUTES=120    # [OPZIONALE]
# BACKUP_OUTPUT_DIR=/app/blockchain_backups   # default; montato su volume nel compose

# --- Telegram bot (solo se usi il profilo 'bot') -----------------------------
TELEGRAM_BOT_TOKEN=                 # [OPZIONALE] token da @BotFather
TELEGRAM_BOT_USERNAME=              # [OPZIONALE] es: FortySealBot (senza @)

# --- PQC ---------------------------------------------------------------------
PQC_ENTROPY_SOURCE=cpu_drng         # [OPZIONALE]
